# ── Postgres ──────────────────────────────────────────
POSTGRES_DB=ai_pool
POSTGRES_USER=ai_pool_user
POSTGRES_PASSWORD=ai_pool_pass

# ── RabbitMQ ──────────────────────────────────────────
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin

# ── Redis ─────────────────────────────────────────────
# (sem auth por padrão no dev)

# ── LLM / IA Provider ────────────────────────────────
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# ── Pool config ──────────────────────────────────────
POOL_TARGET_SIZE=50
POOL_MIN_SIZE=10
