# ── Postgres ──────────────────────────────────────────
POSTGRES_DB=ai_pool
POSTGRES_USER=ai_pool_user
POSTGRES_PASSWORD=ai_pool_pass

# ── RabbitMQ ──────────────────────────────────────────
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_KEY=challenge_pool

# ── LLM / IA Provider ────────────────────────────────
# Escolha: gemini | groq  (se nenhuma key for fornecida, usa mock)
LLM_PROVIDER=gemini
ENABLE_LLM=true

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (free tier disponível em console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Pool config ──────────────────────────────────────
POOL_TARGET_SIZE=50
POOL_MIN_SIZE=10
REFILL_INTERVAL_S=30
