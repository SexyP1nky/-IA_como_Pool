# ── Postgres ──────────────────────────────────────────
POSTGRES_DB=ai_pool
POSTGRES_USER=ai_pool_user
POSTGRES_PASSWORD=ai_pool_pass

# ── RabbitMQ ──────────────────────────────────────────
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin

# ── Redis ─────────────────────────────────────────────
# REDIS_URL tem prioridade; se ausente, usa REDIS_HOST/PORT/DB
REDIS_URL=redis://localhost:6379/0
REDIS_KEY=challenge_pool

# ── LLM / IA Provider ────────────────────────────────
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# ── Pool config ──────────────────────────────────────
POOL_TARGET_SIZE=50
POOL_MIN_SIZE=10
